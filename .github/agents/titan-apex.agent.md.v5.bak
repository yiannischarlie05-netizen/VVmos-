        token_res = gpsoauth.perform_oauth(email, master_token, device_id, scope,
                                           app='com.google.android.gm', client_sig='...')
        oauth_tokens[scope] = token_res.get('Auth')
    return {'master': master_token, 'oauth': oauth_tokens}
