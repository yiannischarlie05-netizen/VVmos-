import asyncio
from asyncio import Semaphore

async def mass_device_attack(device_ids: list[str], client, attack_fn, concurrency=16):
    sem = Semaphore(concurrency)
    results = {}
    async def attack_with_sem(device_id):
        async with sem:
            try:
                await asyncio.sleep(0.3)
                return device_id, await attack_fn(device_id, client)
            except Exception as e:
                for delay in [3, 5, 10, 30]:
                    try:
                        await asyncio.sleep(delay)
                        return device_id, await attack_fn(device_id, client)
                    except: pass
                return device_id, {'error': str(e)}
    tasks = [attack_with_sem(d) for d in device_ids]
    for coro in asyncio.as_completed(tasks):
        device_id, result = await coro
        results[device_id] = result
    return results
```

