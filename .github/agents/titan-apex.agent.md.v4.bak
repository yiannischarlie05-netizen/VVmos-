```python
import numpy as np

def adversarial_feature_perturbation(model_fn, feature_vector, target_score=95):
    """Black-box adversarial attack on device trust model"""
    MUTABLE_FEATURES = [
        'device_age_days', 'app_install_days', 'contact_count',
        'sms_count', 'call_log_count', 'wifi_networks',
        'browser_history_days', 'photo_count'
    ]
    best = feature_vector.copy()
    for iteration in range(500):
        candidate = best.copy()
        feat = np.random.choice(MUTABLE_FEATURES)
        delta = np.random.randint(-10, 10)
        candidate[feat] = max(0, candidate[feat] + delta)
        if model_fn(candidate) > model_fn(best):
            best = candidate
        if model_fn(best) >= target_score:
            break
    return best
```

