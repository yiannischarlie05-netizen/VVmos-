**ADB Bridge Translation** (Local ↔ Cloud API):
```python
async def adb_to_cloud(adb_cmd: str, device_id: str, client) -> str:
    """Translate ADB shell command to VMOS Cloud API call"""
    # Direct shell execution via cloud
    result = await client.sync_cmd(device_id, adb_cmd)
    return result.get('data', {}).get('output', '')

async def cloud_adb_bridge(device_id: str, cmds: list[str], client):
    """Execute multiple ADB commands via cloud API"""
    results = {}
    for cmd in cmds:
        output = await adb_to_cloud(cmd, device_id, client)
        results[cmd] = output
    return results
```

