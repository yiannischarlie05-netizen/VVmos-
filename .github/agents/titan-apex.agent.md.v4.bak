        "TAVV": "Token Authentication Verification Value — per-transaction cryptogram",
        "LUK": "Limited-Use Key — session key derived from MDK/UDK for 1–5 txns",
        "ATC": "Application Transaction Counter — increments per tap"
    },
    "eci_codes": {
        "visa": {"05": "full_3ds_auth", "06": "attempted_auth", "07": "no_auth_frictionless"},
        "mastercard": {"02": "full_3ds_auth", "01": "attempted_auth", "00": "no_auth_frictionless"}
    },
    "zero_auth_bypass": "DPAN tap → TAVV generated → issuer trusts device biometric as SCA → ECI 07/00 → frictionless approval",
    "sca_bypass": "Device-level biometric (fingerprint/face) satisfies SCA requirement → no 3DS challenge",
    "merchant_pre_warm": {
        "phase_1": "$1 auth (verify acceptance, 0hr)",
        "phase_2": "$5 purchase (test fraud filters, +12hr)",
        "phase_3": "$25 purchase (test velocity rules, +24hr)",
        "phase_4": "$100+ purchase (full exploitation, +48hr)"
    }
}
```

