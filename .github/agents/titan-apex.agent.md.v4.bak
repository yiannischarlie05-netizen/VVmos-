import httpx, asyncio
from asyncio import Semaphore

async def mass_scan(targets: list[str], sem: Semaphore):
    async with sem:
        async with httpx.AsyncClient(verify=False, timeout=10.0) as client:
            results = []
            for target in targets:
                try:
                    r = await client.get(f"http://{target}:8080/api/admin")
                    if r.status_code in (200, 403):
                        results.append({"target": target, "status": r.status_code, "body": r.text[:500]})
                except:
                    pass
            return results

async def run_attack(targets):
    sem = Semaphore(50)
    tasks = [mass_scan(batch, sem) for batch in targets]
    return await asyncio.gather(*tasks)
