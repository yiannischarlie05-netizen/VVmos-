# ═══════════════════════════════════════════════════════════════════════
# SECTION: KYC
# ═══════════════════════════════════════════════════════════════════════

def cmd_kyc(args):
    sub = args.kyc_cmd
    did = get_device_id(args)

    if sub == "upload-face":
        header("UPLOAD FACE")
        face_path = Path(args.face_image)
        if not face_path.exists():
            die(f"File not found: {face_path}")
        face_b64 = base64.b64encode(face_path.read_bytes()).decode()
        r = api_post(f"/api/kyc/{did}/upload_face", {"face_b64": face_b64})
        ok("Face uploaded")
        dump_json(r)

    elif sub == "start-deepfake":
        info("Starting deepfake...")
        r = api_post(f"/api/kyc/{did}/start_deepfake")
        ok("Deepfake started")
        dump_json(r)

    elif sub == "stop-deepfake":
        r = api_post(f"/api/kyc/{did}/stop_deepfake")
        ok("Deepfake stopped")

    elif sub == "status":
        r = api_get(f"/api/kyc/{did}/status")
        header("KYC STATUS")
        dump_json(r)

    elif sub == "flow":
        header("KYC FLOW")
        body = {"provider": args.provider or "onfido"}
        if args.face_image:
            face_path = Path(args.face_image)
            if face_path.exists():
                body["face_image"] = base64.b64encode(face_path.read_bytes()).decode()
        r = api_post(f"/api/kyc/{did}/kyc-flow", body, timeout=120)
        dump_json(r)

    elif sub == "voice":
        header("VOICE SYNTHESIS")
        r = api_post(f"/api/kyc/{did}/voice",
                     {"text": args.text, "voice": args.voice or "en-US"}, timeout=30)
        dump_json(r)


# ═══════════════════════════════════════════════════════════════════════
# SECTION: ADMIN
# ═══════════════════════════════════════════════════════════════════════

def cmd_admin(args):
    sub = args.admin_cmd

    if sub == "services":
        r = api_get("/api/admin/services")
        header("SERVICES")
        services = r if isinstance(r, list) else r.get("services", r)
        if isinstance(services, dict):
            for name, status in services.items():
                color = C_GREEN if status in ("active", "running", True) else C_RED
                print(f"  {color}●{C_RESET} {name}: {status}")
        else:
            dump_json(r)

    elif sub == "health":
        r = api_get("/api/admin/health")
        header("ADMIN HEALTH")
        dump_json(r)

    elif sub == "cvd":
        r = api_get("/api/admin/cvd-status")
        header("CUTTLEFISH STATUS")
        dump_json(r)

    elif sub == "kernel":
        r = api_get("/api/admin/kernel-modules")
        header("KERNEL MODULES")
        modules = r if isinstance(r, list) else r.get("modules", r)
        if isinstance(modules, dict):
            for mod, loaded in modules.items():
                color = C_GREEN if loaded else C_RED
                print(f"  {color}{'✓' if loaded else '✗'}{C_RESET} {mod}")
        else:
            dump_json(r)

    elif sub == "cpu":
        r = api_get("/api/admin/cpu")
        header("CPU STATUS")
        dump_json(r)


