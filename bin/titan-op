#!/usr/bin/env python3
"""
titan-op — Titan Operations CLI (mirrors Desktop App)
=====================================================
Full CLI mirror of Cuttlefish Desktop + Titan Console.
Every operation available in the GUI is available here.

Usage:
    titan-op <section> <command> [options]
    titan-op --help

Sections:
    dash        Dashboard & system overview
    device      Device management (permanent device, input, screenshot)
    genesis     Profile forge, inject, provision, reforge
    stealth     Anomaly patching, audit, bootstrap
    agent       AI task automation (See→Think→Act)
    intel       Intelligence, OSINT, recon, 3DS strategy
    network     VPN, proxy, forensic, shield
    cerberus    Card validation, BIN lookup, batch
    targets     Site analysis, WAF, DNS, profiling
    kyc         Face upload, deepfake, voice synthesis
    admin       Services, health, CVD, kernel modules
    bundles     App bundle installation
    training    Workflow, demo recording, scenarios
    ai          LLM query, screen read, faceswap
    viewer      Screen capture, tap, swipe, key
    settings    Read/write platform settings

Environment:
    TITAN_API_PORT   API port (default: 8080)
    TITAN_API_SECRET Auth token (auto-loaded from /opt/titan/.env)
"""

import argparse
import base64
import json
import os
import sys
import time
import textwrap
from pathlib import Path
from urllib.error import URLError, HTTPError
from urllib.request import Request, urlopen

# ═══════════════════════════════════════════════════════════════════════
# CONFIG
# ═══════════════════════════════════════════════════════════════════════

# Load .env
_env_file = Path("/opt/titan/.env")
if _env_file.exists():
    for line in _env_file.read_text().splitlines():
        line = line.strip()
        if line and not line.startswith("#") and "=" in line:
            k, v = line.split("=", 1)
            os.environ.setdefault(k.strip(), v.strip())

API_PORT = os.environ.get("TITAN_API_PORT", "8080")
API_BASE = f"http://127.0.0.1:{API_PORT}"
API_SECRET = os.environ.get("TITAN_API_SECRET", "")
PERMANENT_DEVICE = "titan-permanent-001"
DEFAULT_ADB = "0.0.0.0:6520"

# ═══════════════════════════════════════════════════════════════════════
# HTTP CLIENT
# ═══════════════════════════════════════════════════════════════════════

class ApiError(Exception):
    def __init__(self, status, body):
        self.status = status
        self.body = body
        super().__init__(f"HTTP {status}: {body[:200]}")


def api(method: str, path: str, body: dict = None, timeout: int = 120) -> dict:
    """Make API call. Returns parsed JSON."""
    url = f"{API_BASE}{path}"
    headers = {"Content-Type": "application/json"}
    if API_SECRET:
        headers["Authorization"] = f"Bearer {API_SECRET}"

    data = json.dumps(body).encode() if body else None
    req = Request(url, data=data, headers=headers, method=method)

    try:
        with urlopen(req, timeout=timeout) as resp:
            raw = resp.read()
            if not raw:
                return {}
            return json.loads(raw)
    except HTTPError as e:
        body_text = e.read().decode(errors="replace")
        raise ApiError(e.code, body_text)
    except URLError as e:
        die(f"API unreachable at {API_BASE}: {e.reason}\nStart with: titan-vmos start")


def api_get(path: str, timeout: int = 30) -> dict:
    return api("GET", path, timeout=timeout)


def api_post(path: str, body: dict = None, timeout: int = 120) -> dict:
    return api("POST", path, body or {}, timeout=timeout)


def api_delete(path: str, timeout: int = 30) -> dict:
    return api("DELETE", path, timeout=timeout)


def api_binary(path: str, timeout: int = 30) -> bytes:
    """GET binary response (e.g., screenshot PNG)."""
    url = f"{API_BASE}{path}"
    headers = {}
    if API_SECRET:
        headers["Authorization"] = f"Bearer {API_SECRET}"
    req = Request(url, headers=headers, method="GET")
    try:
        with urlopen(req, timeout=timeout) as resp:
            return resp.read()
    except HTTPError as e:
        raise ApiError(e.code, e.read().decode(errors="replace"))
    except URLError as e:
        die(f"API unreachable: {e.reason}")


# ═══════════════════════════════════════════════════════════════════════
# OUTPUT HELPERS
# ═══════════════════════════════════════════════════════════════════════

# ANSI
C_RESET = "\033[0m"
C_BOLD = "\033[1m"
C_DIM = "\033[2m"
C_RED = "\033[31m"
C_GREEN = "\033[32m"
C_YELLOW = "\033[33m"
C_CYAN = "\033[36m"
C_MAGENTA = "\033[35m"
C_WHITE = "\033[97m"


def die(msg: str):
    print(f"{C_RED}ERROR:{C_RESET} {msg}", file=sys.stderr)
    sys.exit(1)


def ok(msg: str = ""):
    print(f"{C_GREEN}✓{C_RESET} {msg}")


def warn(msg: str):
    print(f"{C_YELLOW}⚠{C_RESET} {msg}")


def info(msg: str):
    print(f"{C_CYAN}→{C_RESET} {msg}")


def header(title: str):
    print(f"\n{C_BOLD}{C_CYAN}═══ {title} ═══{C_RESET}")


def kv(key: str, val, indent: int = 2):
    pad = " " * indent
    if isinstance(val, bool):
        color = C_GREEN if val else C_RED
        print(f"{pad}{C_DIM}{key}:{C_RESET} {color}{val}{C_RESET}")
    elif isinstance(val, (int, float)):
        print(f"{pad}{C_DIM}{key}:{C_RESET} {C_WHITE}{val}{C_RESET}")
    else:
        print(f"{pad}{C_DIM}{key}:{C_RESET} {val}")


def dump_json(data: dict, indent: int = 2):
    """Pretty-print JSON with colors."""
    print(json.dumps(data, indent=indent, default=str))


def table(rows: list, headers: list = None):
    """Simple ASCII table."""
    if not rows:
        print("  (empty)")
        return
    if headers:
        rows = [headers] + rows
    widths = [max(len(str(row[i])) for row in rows) for i in range(len(rows[0]))]
    for i, row in enumerate(rows):
        line = "  ".join(str(row[j]).ljust(widths[j]) for j in range(len(row)))
        if i == 0 and headers:
            print(f"  {C_BOLD}{line}{C_RESET}")
            print(f"  {'  '.join('─' * w for w in widths)}")
        else:
            print(f"  {line}")


def poll_job(status_path: str, interval: float = 3.0, timeout: int = 600):
    """Poll a job status endpoint until completion."""
    start = time.time()
    last_phase = ""
    while time.time() - start < timeout:
        r = api_get(status_path)
        status = r.get("status", r.get("state", "unknown"))
        phase = r.get("current_phase", r.get("phase", ""))
        progress = r.get("progress", "")

        if phase != last_phase:
            info(f"[{status}] {phase} {progress}")
            last_phase = phase

        if status in ("completed", "done", "success", "finished"):
            ok(f"Job completed in {int(time.time() - start)}s")
            return r
        if status in ("failed", "error", "aborted"):
            die(f"Job failed: {r.get('error', r.get('message', status))}")

        time.sleep(interval)

    die(f"Job timed out after {timeout}s")


def get_device_id(args) -> str:
    return getattr(args, "device_id", None) or PERMANENT_DEVICE


# ═══════════════════════════════════════════════════════════════════════
# SECTION: DASHBOARD
# ═══════════════════════════════════════════════════════════════════════

def cmd_dash(args):
    sub = args.dash_cmd

    if sub == "summary":
        header("DASHBOARD SUMMARY")
        try:
            r = api_get("/api/dashboard/summary")
            for k, v in r.items():
                if isinstance(v, dict):
                    print(f"  {C_BOLD}{k}:{C_RESET}")
                    for sk, sv in v.items():
                        kv(sk, sv, 4)
                else:
                    kv(k, v)
        except ApiError:
            warn("Dashboard endpoint not available, falling back to health check")
            r = api_get("/health")
            for k, v in r.items():
                kv(k, v)

    elif sub == "health":
        header("SYSTEM HEALTH")
        r = api_get("/health")
        kv("status", r.get("status"))
        for name, check in r.get("checks", {}).items():
            ok_val = check.get("ok", False)
            color = C_GREEN if ok_val else C_RED
            detail = {k: v for k, v in check.items() if k != "ok"}
            print(f"  {color}{'✓' if ok_val else '✗'}{C_RESET} {name}: {detail}")

    elif sub == "version":
        r = api_get("/api/version")
        for k, v in r.items():
            kv(k, v)

    elif sub == "metrics":
        r = api_get("/api/metrics")
        dump_json(r)


# ═══════════════════════════════════════════════════════════════════════
# SECTION: DEVICE
# ═══════════════════════════════════════════════════════════════════════

def cmd_device(args):
    sub = args.device_cmd
    did = get_device_id(args)

    if sub == "status":
        header("PERMANENT DEVICE STATUS")
        try:
            r = api_get("/api/devices/permanent")
            kv("id", r.get("id", r.get("device_id")))
            kv("state", r.get("state"))
            kv("adb_target", r.get("adb_target"))
            kv("model", r.get("model", r.get("preset")))
            kv("uptime", r.get("uptime", "N/A"))
            score = r.get("stealth_score", r.get("trust_score", "N/A"))
            kv("stealth_score", score)
        except ApiError:
            r = api_get("/api/devices")
            if isinstance(r, list) and r:
                d = r[0] if isinstance(r[0], dict) else r[0].__dict__
                for k, v in (d if isinstance(d, dict) else {"device": d}).items():
                    kv(k, v)
            else:
                warn("No devices found")

    elif sub == "list":
        r = api_get("/api/devices")
        devs = r if isinstance(r, list) else r.get("devices", [r])
        if not devs:
            warn("No devices")
            return
        rows = []
        for d in devs:
            if isinstance(d, dict):
                rows.append([d.get("id", "?"), d.get("state", "?"),
                             d.get("adb_target", "?"), d.get("model", d.get("preset", "?"))])
            else:
                rows.append([str(d)])
        table(rows, ["ID", "State", "ADB", "Model"])

    elif sub == "reset":
        header("FACTORY RESET")
        info(f"Resetting device {did}...")
        r = api_post(f"/api/devices/factory-reset", {"device_id": did}, timeout=300)
        ok(f"Factory reset initiated")
        dump_json(r)

    elif sub == "config":
        header("DEVICE CONFIG")
        if args.model or args.carrier or args.country or args.location:
            body = {}
            if args.model:
                body["model"] = args.model
            if args.carrier:
                body["carrier"] = args.carrier
            if args.country:
                body["country"] = args.country
            if args.location:
                body["location"] = args.location
            r = api_post(f"/api/devices/permanent/config", body)
            ok("Config updated")
            dump_json(r)
        else:
            r = api_get("/api/devices/permanent")
            dump_json(r)

    elif sub == "screenshot":
        out = args.output or f"/tmp/titan_screenshot_{int(time.time())}.png"
        info(f"Capturing screenshot → {out}")
        try:
            data = api_binary(f"/api/devices/{did}/screenshot")
            Path(out).write_bytes(data)
            ok(f"Screenshot saved: {out} ({len(data)} bytes)")
        except ApiError:
            # Fallback: viewer endpoint
            data = api_binary(f"/api/viewer/{did}/screen")
            Path(out).write_bytes(data)
            ok(f"Screenshot saved: {out} ({len(data)} bytes)")

    elif sub == "tap":
        x, y = int(args.x), int(args.y)
        api_post(f"/api/viewer/{did}/tap", {"x": x, "y": y})
        ok(f"Tap ({x}, {y})")

    elif sub == "swipe":
        body = {"x1": int(args.x1), "y1": int(args.y1),
                "x2": int(args.x2), "y2": int(args.y2),
                "duration": int(args.duration or 300)}
        api_post(f"/api/viewer/{did}/swipe", body)
        ok(f"Swipe ({body['x1']},{body['y1']}) → ({body['x2']},{body['y2']})")

    elif sub == "key":
        api_post(f"/api/viewer/{did}/key", {"code": args.code})
        ok(f"Key: {args.code}")

    elif sub == "text":
        api_post(f"/api/devices/{did}/input", {"type": "text", "text": args.text})
        ok(f"Typed: {args.text[:40]}...")

    elif sub == "home":
        api_post(f"/api/viewer/{did}/key", {"code": "KEYCODE_HOME"})
        ok("Home")

    elif sub == "back":
        api_post(f"/api/viewer/{did}/key", {"code": "KEYCODE_BACK"})
        ok("Back")

    elif sub == "scroll-down":
        api_post(f"/api/viewer/{did}/swipe",
                 {"x1": 360, "y1": 1000, "x2": 360, "y2": 400, "duration": 300})
        ok("Scroll down")

    elif sub == "scroll-up":
        api_post(f"/api/viewer/{did}/swipe",
                 {"x1": 360, "y1": 400, "x2": 360, "y2": 1000, "duration": 300})
        ok("Scroll up")


# ═══════════════════════════════════════════════════════════════════════
# SECTION: GENESIS (Profile Forge + Inject + Pipeline)
# ═══════════════════════════════════════════════════════════════════════

def cmd_genesis(args):
    sub = args.genesis_cmd
    did = get_device_id(args)

    if sub == "forge":
        header("FORGE PROFILE")
        body = {
            "name": args.name or "Auto User",
            "email": args.email or "",
            "country": args.country or "US",
            "age_days": int(args.age_days or 90),
        }
        if args.phone:
            body["phone"] = args.phone
        if args.carrier:
            body["carrier"] = args.carrier
        if args.archetype:
            body["archetype"] = args.archetype
        if args.occupation:
            body["occupation"] = args.occupation
        # Address fields
        for fld in ("street", "city", "state", "zip", "dob", "ssn"):
            val = getattr(args, fld, None)
            if val:
                body[fld] = val
        # CC fields (stored in profile for later pipeline use)
        if getattr(args, "cc_number", None):
            body["cc_number"] = args.cc_number
        if getattr(args, "cc_exp", None):
            body["cc_exp"] = args.cc_exp
        if getattr(args, "cc_cvv", None):
            body["cc_cvv"] = args.cc_cvv
        if getattr(args, "cardholder", None):
            body["cc_cardholder"] = args.cardholder

        info("Forging profile...")
        r = api_post("/api/genesis/create", body)
        ok(f"Profile forged")
        kv("profile_id", r.get("profile_id", r.get("id")))
        kv("name", r.get("name", body["name"]))
        kv("country", r.get("country", body["country"]))
        dump_json({k: v for k, v in r.items() if k not in ("profile_data",)})

    elif sub == "smartforge":
        header("SMART FORGE")
        body = {
            "country": args.country or "US",
            "age_days": int(args.age_days or 90),
        }
        if args.occupation:
            body["occupation"] = args.occupation
        if args.archetype:
            body["archetype"] = args.archetype
        r = api_post("/api/genesis/smartforge", body)
        ok("SmartForge complete")
        kv("profile_id", r.get("profile_id", r.get("id")))
        dump_json(r)

    elif sub == "profiles":
        header("PROFILES")
        r = api_get("/api/genesis/profiles")
        profiles = r if isinstance(r, list) else r.get("profiles", [])
        if not profiles:
            warn("No profiles")
            return
        rows = []
        for p in profiles:
            rows.append([
                p.get("id", p.get("profile_id", "?"))[:16],
                p.get("name", "?"),
                p.get("country", "?"),
                str(p.get("age_days", "?")),
                str(p.get("trust_score", "?"))
            ])
        table(rows, ["ID", "Name", "Country", "Age", "Trust"])

    elif sub == "inject":
        header("INJECT PROFILE")
        body = {"profile_id": args.profile_id, "age_days": int(args.age_days or 90)}
        if args.cc_number:
            body["cc_number"] = args.cc_number
        if args.cc_exp:
            parts = args.cc_exp.split("/")
            body["exp_month"] = parts[0]
            body["exp_year"] = parts[1] if len(parts) > 1 else ""
        if args.cc_cvv:
            body["cvv"] = args.cc_cvv
        if args.cardholder:
            body["cardholder"] = args.cardholder

        info(f"Injecting profile {args.profile_id[:16]}... into {did}")
        r = api_post(f"/api/genesis/inject/{did}", body, timeout=300)
        ok("Injection complete")
        kv("trust_score", r.get("trust_score"))
        kv("phases_ok", r.get("phases_ok", r.get("phases_completed")))
        dump_json(r)

    elif sub == "provision":
        header("FULL PROVISION PIPELINE")
        body = {
            "country": getattr(args, "country", "US") or "US",
            "age_days": int(getattr(args, "age_days", 90) or 90),
        }
        # Identity fields
        for fld in ("name", "email", "phone", "dob", "ssn", "gender", "occupation"):
            val = getattr(args, fld, None)
            if val:
                body[fld] = val
        # Address fields
        for fld in ("street", "city", "state", "zip"):
            val = getattr(args, fld, None)
            if val:
                body[fld] = val
        # Device config
        if getattr(args, "carrier", None):
            body["carrier"] = args.carrier
        if getattr(args, "device_model", None):
            body["device_model"] = args.device_model
        if getattr(args, "location", None):
            body["location"] = args.location
        # Network
        if getattr(args, "proxy", None):
            body["proxy_url"] = args.proxy
        # Google sign-in
        if getattr(args, "google_email", None):
            body["google_email"] = args.google_email
        if getattr(args, "google_password", None):
            body["google_password"] = args.google_password
        if getattr(args, "real_phone", None):
            body["real_phone"] = args.real_phone
        if getattr(args, "otp_code", None):
            body["otp_code"] = args.otp_code
        # Card data
        if getattr(args, "cc_number", None):
            body["cc_number"] = args.cc_number
        if getattr(args, "cc_exp", None):
            body["cc_exp"] = args.cc_exp
        if getattr(args, "cc_cvv", None):
            body["cc_cvv"] = args.cc_cvv
        if getattr(args, "cardholder", None):
            body["cc_holder"] = args.cardholder
        # Options
        if getattr(args, "lockdown", False):
            body["lockdown"] = True
        if getattr(args, "skip_wipe", False):
            body["skip_wipe"] = True
        if getattr(args, "skip_patch", False):
            body["skip_patch"] = True

        info(f"Starting full pipeline on {did}...")
        r = api_post(f"/api/genesis/pipeline/{did}", body, timeout=600)
        if "job_id" in r:
            poll_job(f"/api/genesis/pipeline-status/{r['job_id']}", interval=5, timeout=900)
        else:
            ok("Pipeline complete")
            dump_json(r)

    elif sub == "reforge":
        header("RE-FORGE IDENTITY")
        body = {}
        if args.model:
            body["model"] = args.model
        if args.country:
            body["country"] = args.country
        if args.carrier:
            body["carrier"] = args.carrier
        if args.location:
            body["location"] = args.location
        if args.age_days:
            body["age_days"] = int(args.age_days)

        info(f"Re-forging device {did}...")
        r = api_post("/api/genesis/reforge", body, timeout=600)
        if "job_id" in r:
            poll_job(f"/api/genesis/provision-status/{r['job_id']}", interval=5, timeout=900)
        else:
            ok("Re-forge complete")
            dump_json(r)

    elif sub == "trust-score":
        r = api_get(f"/api/genesis/trust-score?device_id={did}")
        header("TRUST SCORE")
        score = r.get("score", r.get("trust_score", "?"))
        grade = r.get("grade", "?")
        print(f"  {C_BOLD}{C_GREEN if str(score) >= '80' else C_YELLOW}{score}/100 (Grade: {grade}){C_RESET}")
        for check in r.get("checks", r.get("details", [])):
            if isinstance(check, dict):
                name = check.get("name", check.get("check", "?"))
                pts = check.get("score", check.get("points", "?"))
                mx = check.get("max", check.get("weight", "?"))
                print(f"    {'✓' if pts == mx else '○'} {name}: {pts}/{mx}")

    elif sub == "wallet-status":
        r = api_get(f"/api/genesis/wallet-status/{did}")
        header("WALLET STATUS")
        dump_json(r)

    elif sub == "delete-profile":
        api_delete(f"/api/genesis/profiles/{args.profile_id}")
        ok(f"Profile {args.profile_id} deleted")

    elif sub == "inspect":
        r = api_get(f"/api/genesis/profiles/{args.profile_id}/inspect")
        header(f"PROFILE INSPECT: {args.profile_id[:16]}")
        dump_json(r)


# ═══════════════════════════════════════════════════════════════════════
# SECTION: STEALTH
# ═══════════════════════════════════════════════════════════════════════

def cmd_stealth(args):
    sub = args.stealth_cmd
    did = get_device_id(args)

    if sub == "patch":
        header("STEALTH PATCH")
        body = {}
        if args.preset:
            body["preset"] = args.preset
        if args.carrier:
            body["carrier"] = args.carrier
        if args.location:
            body["location"] = args.location
        if args.age_days:
            body["age_days"] = int(args.age_days)
        if args.lockdown:
            body["lockdown"] = True

        info(f"Patching device {did} (26 phases, ~200-365s)...")
        r = api_post(f"/api/stealth/{did}/patch", body, timeout=600)
        if "job_id" in r:
            result = poll_job(f"/api/stealth/{did}/patch-status/{r['job_id']}",
                              interval=5, timeout=600)
            kv("stealth_score", result.get("stealth_score"))
        else:
            ok("Patch complete")
            kv("stealth_score", r.get("stealth_score"))
            dump_json(r)

    elif sub == "audit":
        header("STEALTH AUDIT")
        info(f"Scanning 103+ vectors on {did}...")
        r = api_get(f"/api/stealth/{did}/audit", timeout=120)
        score = r.get("overall_score", r.get("stealth_score", "?"))
        print(f"  {C_BOLD}Overall: {score}%{C_RESET}")
        for cat, details in r.items():
            if isinstance(details, dict) and cat not in ("overall_score", "stealth_score", "device_id"):
                status = details.get("status", details.get("ok", "?"))
                color = C_GREEN if status in (True, "pass", "ok") else C_RED
                print(f"  {color}{'✓' if status in (True, 'pass', 'ok') else '✗'}{C_RESET} {cat}")

    elif sub == "bootstrap":
        header("BOOTSTRAP GAPPS")
        info(f"Installing GMS + Play Store + Chrome + Wallet on {did}...")
        r = api_post(f"/api/stealth/{did}/bootstrap-gapps", {}, timeout=300)
        if "job_id" in r:
            poll_job(f"/api/stealth/{did}/gapps-status", interval=5, timeout=300)
        else:
            ok("Bootstrap complete")
            dump_json(r)

    elif sub == "presets":
        r = api_get("/api/stealth/presets")
        header("DEVICE PRESETS")
        presets = r if isinstance(r, list) else r.get("presets", [])
        for p in presets:
            if isinstance(p, dict):
                print(f"  {C_CYAN}{p.get('name', p.get('id', '?'))}{C_RESET} — {p.get('brand', '')} {p.get('model', '')}")
            else:
                print(f"  {p}")

    elif sub == "carriers":
        r = api_get("/api/stealth/carriers")
        header("CARRIERS")
        carriers = r if isinstance(r, list) else r.get("carriers", [])
        for c in carriers:
            if isinstance(c, dict):
                print(f"  {C_CYAN}{c.get('name', c.get('id', '?'))}{C_RESET} — {c.get('country', '')} {c.get('mcc', '')}/{c.get('mnc', '')}")
            else:
                print(f"  {c}")

    elif sub == "locations":
        r = api_get("/api/stealth/locations")
        header("LOCATIONS")
        locations = r if isinstance(r, list) else r.get("locations", [])
        for loc in locations:
            if isinstance(loc, dict):
                print(f"  {C_CYAN}{loc.get('name', loc.get('id', '?'))}{C_RESET} — {loc.get('city', '')} {loc.get('country', '')}")
            else:
                print(f"  {loc}")


# ═══════════════════════════════════════════════════════════════════════
# SECTION: AGENT
# ═══════════════════════════════════════════════════════════════════════

def cmd_agent(args):
    sub = args.agent_cmd
    did = get_device_id(args)

    if sub == "start":
        header("START AI TASK")
        body = {"prompt": args.prompt}
        if args.template:
            body["template"] = args.template
        if args.max_steps:
            body["max_steps"] = int(args.max_steps)
        if args.persona:
            body["persona"] = args.persona

        info(f"Starting AI task on {did}...")
        r = api_post(f"/api/agent/task/{did}", body, timeout=30)
        task_id = r.get("task_id", r.get("id"))
        ok(f"Task started: {task_id}")

        if args.wait:
            poll_job(f"/api/agent/task/{did}/{task_id}", interval=3, timeout=int(args.timeout or 600))

    elif sub == "stop":
        r = api_post(f"/api/agent/stop/{did}/{args.task_id}")
        ok(f"Task {args.task_id} stopped")

    elif sub == "status":
        r = api_get(f"/api/agent/task/{did}/{args.task_id}")
        header("TASK STATUS")
        dump_json(r)

    elif sub == "tasks":
        r = api_get(f"/api/agent/tasks/{did}")
        header("ACTIVE TASKS")
        tasks = r if isinstance(r, list) else r.get("tasks", [])
        if not tasks:
            warn("No active tasks")
            return
        for t in tasks:
            if isinstance(t, dict):
                kv(t.get("task_id", "?"), t.get("status", "?"))

    elif sub == "templates":
        r = api_get("/api/agent/templates")
        header("TASK TEMPLATES")
        templates = r if isinstance(r, list) else r.get("templates", [])
        for t in templates:
            if isinstance(t, dict):
                print(f"  {C_CYAN}{t.get('id', t.get('name', '?'))}{C_RESET} — {t.get('description', t.get('category', ''))}")
            else:
                print(f"  {t}")

    elif sub == "screen":
        header("SCREEN ANALYSIS")
        r = api_get(f"/api/agent/screen/{did}", timeout=30)
        dump_json(r)

    elif sub == "models":
        r = api_get("/api/agent/models")
        header("LLM MODELS")
        dump_json(r)


