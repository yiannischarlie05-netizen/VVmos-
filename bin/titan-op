# SECTION: BUNDLES
# ═══════════════════════════════════════════════════════════════════════

def cmd_bundles(args):
    sub = args.bundles_cmd
    did = get_device_id(args)

    if sub == "list":
        r = api_get(f"/api/bundles" + (f"/{args.country}" if args.country else ""))
        header("APP BUNDLES")
        bundles = r if isinstance(r, list) else r.get("bundles", [])
        for b in bundles:
            if isinstance(b, dict):
                count = len(b.get("packages", b.get("apps", [])))
                print(f"  {C_CYAN}{b.get('name', b.get('id', '?'))}{C_RESET} ({count} apps) — {b.get('description', '')}")
            else:
                print(f"  {b}")

    elif sub == "install":
        header(f"INSTALL BUNDLE: {args.bundle}")
        body = {"bundle": args.bundle}
        if args.packages:
            body["packages"] = args.packages.split(",")
        info(f"Installing {args.bundle} on {did}...")
        r = api_post(f"/api/bundles/{did}/install", body, timeout=300)
        ok("Bundle installation started")
        dump_json(r)


# ═══════════════════════════════════════════════════════════════════════
# SECTION: TRAINING
# ═══════════════════════════════════════════════════════════════════════

def cmd_training(args):
    sub = args.training_cmd
    did = get_device_id(args)

    if sub == "start":
        header("START WORKFLOW")
        body = {}
        if args.aging_level:
            body["aging_level"] = args.aging_level
        if args.country:
            body["country"] = args.country
        if args.disable_adb:
            body["disable_adb"] = True
        r = api_post(f"/api/training/workflow/start/{did}", body, timeout=30)
        job_id = r.get("job_id", r.get("id"))
        ok(f"Workflow started: {job_id}")
        if args.wait:
            poll_job(f"/api/training/workflow/status/{job_id}", interval=5, timeout=int(args.timeout or 1800))

    elif sub == "status":
        r = api_get(f"/api/training/workflow/status/{args.job_id}")
        header("WORKFLOW STATUS")
        dump_json(r)

    elif sub == "jobs":
        r = api_get("/api/training/workflow/jobs")
        header("WORKFLOW JOBS")
        jobs = r if isinstance(r, list) else r.get("jobs", [])
        if not jobs:
            warn("No jobs")
            return
        rows = []
        for j in jobs:
            if isinstance(j, dict):
                rows.append([j.get("job_id", "?")[:16], j.get("status", "?"),
                             j.get("device_id", "?"), j.get("stage", "?")])
        table(rows, ["Job", "Status", "Device", "Stage"])

    elif sub == "report":
        r = api_get(f"/api/training/report/{did}")
        header("AGING REPORT")
        dump_json(r)

    elif sub == "verify":
        r = api_post(f"/api/training/verify/{did}")
        header("VERIFICATION")
        dump_json(r)

    elif sub == "record-start":
        body = {"prompt": args.prompt or "demo", "task_category": args.category or "general"}
        r = api_post(f"/api/training/demo/start/{did}", body)
        ok(f"Recording started: {r.get('session_id', r.get('id'))}")

    elif sub == "record-stop":
        r = api_post(f"/api/training/demo/stop/{args.session_id}")
        ok("Recording stopped")

    elif sub == "recordings":
        r = api_get("/api/training/demo/sessions")
        header("RECORDINGS")
        dump_json(r)

    elif sub == "scenario":
        body = {"scenario": args.scenario}
        if args.params:
            body["params"] = json.loads(args.params)
        r = api_post("/api/training/scenarios/run", body, timeout=120)
        ok("Scenario started")
        dump_json(r)


# ═══════════════════════════════════════════════════════════════════════
# SECTION: AI
# ═══════════════════════════════════════════════════════════════════════

def cmd_ai(args):
    sub = args.ai_cmd
    did = get_device_id(args)

    if sub == "status":
        r = api_get("/api/ai/status")
        header("AI STATUS")
        dump_json(r)

    elif sub == "query":
        r = api_post("/api/ai/query", {
            "prompt": args.prompt,
            "model": args.model or "titan-agent:7b"
        }, timeout=60)
        print(f"\n{r.get('response', r.get('result', json.dumps(r)))}\n")

    elif sub == "screen":
        header("SCREEN READ")
        r = api_get(f"/api/ai/screen/{did}", timeout=30)
        dump_json(r)

    elif sub == "task":
        body = {"task": args.task, "max_steps": int(args.max_steps or 20)}
        r = api_post(f"/api/ai/screen/{did}/task", body, timeout=120)
        dump_json(r)

    elif sub == "tap":
        r = api_post(f"/api/ai/screen/{did}/tap", {"x": int(args.x), "y": int(args.y)})
        ok(f"AI tap ({args.x}, {args.y})")

    elif sub == "type":
        r = api_post(f"/api/ai/screen/{did}/type", {"text": args.text})
        ok(f"AI type: {args.text[:40]}")

    elif sub == "faceswap":
        body = {}
        if args.source:
            body["source_b64"] = base64.b64encode(Path(args.source).read_bytes()).decode()
        if args.target:
            body["target_b64"] = base64.b64encode(Path(args.target).read_bytes()).decode()
        r = api_post("/api/ai/faceswap", body, timeout=60)
        ok("Faceswap complete")
        dump_json(r)


# ═══════════════════════════════════════════════════════════════════════
# SECTION: SETTINGS
# ═══════════════════════════════════════════════════════════════════════

def cmd_settings(args):
    sub = args.settings_cmd

    if sub == "get":
        r = api_get("/api/settings")
        header("SETTINGS")
        dump_json(r)

    elif sub == "set":
        body = {}
        for pair in args.values:
            k, v = pair.split("=", 1)
            # Try to parse as JSON value
            try:
                body[k] = json.loads(v)
            except (json.JSONDecodeError, ValueError):
                body[k] = v
        r = api_post("/api/settings", body)
        ok("Settings updated")
        dump_json(r)


# ═══════════════════════════════════════════════════════════════════════
# ARGPARSE — BUILD CLI STRUCTURE
# ═══════════════════════════════════════════════════════════════════════

def build_parser():
    p = argparse.ArgumentParser(
        prog="titan-op",
        description="Titan Operations CLI — mirrors Desktop App (134 operations)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""
        Examples:
          titan-op dash summary                   System overview
          titan-op device status                  Permanent device info
          titan-op device tap 540 1200            Tap screen
          titan-op device text "hello world"      Type text
          titan-op genesis forge --name "John" --country US --age-days 90
          titan-op genesis inject PROFILE_ID      Inject profile
          titan-op genesis trust-score            Trust score check
          titan-op stealth patch                  Run 26-phase stealth patch
          titan-op stealth audit                  Audit 103+ vectors
          titan-op agent start "Browse news"      Start AI task
          titan-op cerberus validate 4111...      Validate card
          titan-op cerberus bin 411111            BIN lookup
          titan-op intel copilot "plan attack"    AI copilot
          titan-op admin services                 Service status
          titan-op ai query "what is this?"       LLM query
        """)
    )
    p.add_argument("--json", action="store_true", help="Raw JSON output")
    p.add_argument("--device-id", "-d", default=None, help=f"Device ID (default: {PERMANENT_DEVICE})")
    sub = p.add_subparsers(dest="section", required=True)

    # ── DASH ──────────────────────────────────────────────────────────
    dash = sub.add_parser("dash", help="Dashboard & health")
    dash_sub = dash.add_subparsers(dest="dash_cmd", required=True)
    dash_sub.add_parser("summary", help="Dashboard summary")
    dash_sub.add_parser("health", help="System health")
    dash_sub.add_parser("version", help="API version")
    dash_sub.add_parser("metrics", help="Metrics (JSON)")

    # ── DEVICE ────────────────────────────────────────────────────────
    dev = sub.add_parser("device", aliases=["dev", "d"], help="Device management")
    dev_sub = dev.add_subparsers(dest="device_cmd", required=True)
    dev_sub.add_parser("status", help="Permanent device status")
    dev_sub.add_parser("list", help="List all devices")
    dev_sub.add_parser("reset", help="Factory reset permanent device")

    cfg = dev_sub.add_parser("config", help="View/update device config")
    cfg.add_argument("--model", help="Device model preset")
    cfg.add_argument("--carrier", help="Carrier")
    cfg.add_argument("--country", help="Country")
    cfg.add_argument("--location", help="Location")

    ss = dev_sub.add_parser("screenshot", aliases=["ss"], help="Capture screenshot")
    ss.add_argument("--output", "-o", help="Output file path")

    tap = dev_sub.add_parser("tap", help="Tap screen at (x, y)")
    tap.add_argument("x", help="X coordinate")
    tap.add_argument("y", help="Y coordinate")

    swipe = dev_sub.add_parser("swipe", help="Swipe from (x1,y1) to (x2,y2)")
    swipe.add_argument("x1"); swipe.add_argument("y1")
    swipe.add_argument("x2"); swipe.add_argument("y2")
    swipe.add_argument("--duration", default="300", help="Duration ms (default: 300)")

    key = dev_sub.add_parser("key", help="Send keycode")
    key.add_argument("code", help="Android keycode (e.g. KEYCODE_BACK)")

    txt = dev_sub.add_parser("text", help="Type text")
    txt.add_argument("text", help="Text to type")

    dev_sub.add_parser("home", help="Press Home")
    dev_sub.add_parser("back", help="Press Back")
    dev_sub.add_parser("scroll-down", help="Scroll down")
    dev_sub.add_parser("scroll-up", help="Scroll up")

    # ── GENESIS ───────────────────────────────────────────────────────
    gen = sub.add_parser("genesis", aliases=["gen", "g"], help="Profile forge/inject/provision")
    gen_sub = gen.add_subparsers(dest="genesis_cmd", required=True)

    forge = gen_sub.add_parser("forge", help="Forge a new profile")
    forge.add_argument("--name", help="Persona name")
    forge.add_argument("--email", help="Email")
    forge.add_argument("--phone", help="Phone")
    forge.add_argument("--country", default="US")
    forge.add_argument("--carrier", help="Carrier")
    forge.add_argument("--age-days", default="90")
    forge.add_argument("--archetype", help="professional|student|night_shift|retiree|gamer")
    forge.add_argument("--occupation", help="Occupation for life-path")
    # Address fields
    forge.add_argument("--street", help="Street address")
    forge.add_argument("--city", help="City")
    forge.add_argument("--state", help="State (2-letter)")
    forge.add_argument("--zip", help="ZIP code")
    forge.add_argument("--dob", help="Date of birth (MM/DD/YYYY)")
    forge.add_argument("--ssn", help="SSN")
    # Card data (embedded in profile)
    forge.add_argument("--cc-number", help="Credit card number")
    forge.add_argument("--cc-exp", help="Expiry MM/YYYY")
    forge.add_argument("--cc-cvv", help="CVV")
    forge.add_argument("--cardholder", help="Cardholder name")

    sf = gen_sub.add_parser("smartforge", help="Auto-generate optimal profile")
    sf.add_argument("--country", default="US")
    sf.add_argument("--age-days", default="90")
    sf.add_argument("--occupation", help="Occupation")
    sf.add_argument("--archetype", help="Archetype")

    gen_sub.add_parser("profiles", help="List all profiles")

    inj = gen_sub.add_parser("inject", help="Inject profile into device")
    inj.add_argument("profile_id", help="Profile ID to inject")
    inj.add_argument("--age-days", default="90")
    inj.add_argument("--cc-number", help="Credit card number")
    inj.add_argument("--cc-exp", help="Expiry MM/YYYY")
    inj.add_argument("--cc-cvv", help="CVV")
