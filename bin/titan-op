# ═══════════════════════════════════════════════════════════════════════
# DISPATCH
# ═══════════════════════════════════════════════════════════════════════

DISPATCH = {
    "dash": cmd_dash,
    "device": cmd_device, "dev": cmd_device, "d": cmd_device,
    "genesis": cmd_genesis, "gen": cmd_genesis, "g": cmd_genesis,
    "stealth": cmd_stealth, "stl": cmd_stealth, "s": cmd_stealth,
    "agent": cmd_agent, "ag": cmd_agent, "a": cmd_agent,
    "intel": cmd_intel, "in": cmd_intel, "i": cmd_intel,
    "network": cmd_network, "net": cmd_network, "n": cmd_network,
    "cerberus": cmd_cerberus, "cb": cmd_cerberus, "c": cmd_cerberus,
    "targets": cmd_targets, "tgt": cmd_targets, "t": cmd_targets,
    "kyc": cmd_kyc, "k": cmd_kyc,
    "admin": cmd_admin, "adm": cmd_admin,
    "bundles": cmd_bundles, "bnd": cmd_bundles, "b": cmd_bundles,
    "training": cmd_training, "trn": cmd_training,
    "ai": cmd_ai,
    "settings": cmd_settings, "cfg": cmd_settings,
}


def main():
    parser = build_parser()
    args = parser.parse_args()

    if not args.section:
        parser.print_help()
        sys.exit(0)

    handler = DISPATCH.get(args.section)
    if not handler:
        die(f"Unknown section: {args.section}")

    try:
        handler(args)
    except ApiError as e:
        die(f"API error {e.status}: {e.body[:500]}")
    except KeyboardInterrupt:
        print("\nAborted.")
        sys.exit(130)
    except Exception as e:
        die(f"{type(e).__name__}: {e}")


if __name__ == "__main__":
    main()
