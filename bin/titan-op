def cmd_cerberus(args):
    sub = args.cerberus_cmd

    if sub == "validate":
        header("CARD VALIDATION")
        r = api_post("/api/cerberus/validate", {"card_number": args.card})
        kv("valid", r.get("valid"))
        kv("brand", r.get("brand", r.get("network")))
        kv("luhn", r.get("luhn_valid", r.get("luhn")))
        dump_json(r)

    elif sub == "batch":
        cards = [c.strip() for c in args.cards.split(",")]
        header(f"BATCH VALIDATE ({len(cards)} cards)")
        r = api_post("/api/cerberus/batch", {"cards": cards})
        dump_json(r)

    elif sub == "bin":
        header(f"BIN LOOKUP: {args.bin}")
        r = api_post("/api/cerberus/bin-lookup", {"bin": args.bin})
        kv("issuer", r.get("issuer", r.get("bank")))
        kv("country", r.get("country"))
        kv("type", r.get("type", r.get("card_type")))
        kv("brand", r.get("brand", r.get("network")))
        kv("prepaid", r.get("prepaid"))
        dump_json(r)

    elif sub == "intel":
        header("CARD INTELLIGENCE")
        body = {"bin": args.bin}
        if args.merchant:
            body["merchant"] = args.merchant
        if args.amount:
            body["amount"] = float(args.amount)
        r = api_post("/api/cerberus/intelligence", body)
        dump_json(r)


