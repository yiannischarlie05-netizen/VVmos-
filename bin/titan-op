    elif sub == "recon":
        header(f"RECON: {args.domain}")
        r = api_post("/api/intel/recon", {"domain": args.domain}, timeout=60)
        dump_json(r)

    elif sub == "osint":
        header("OSINT SEARCH")
        body = {}
        if args.name:
            body["name"] = args.name
        if args.email:
            body["email"] = args.email
        if args.username:
            body["username"] = args.username
        if args.phone:
            body["phone"] = args.phone
        if args.domain:
            body["domain"] = args.domain

        info("Running OSINT...")
        r = api_post("/api/intel/osint", body, timeout=120)
        dump_json(r)

    elif sub == "3ds":
        header("3DS STRATEGY")
        body = {"bin": args.bin}
        if args.merchant:
            body["merchant"] = args.merchant
        if args.amount:
            body["amount"] = float(args.amount)
        r = api_post("/api/intel/3ds-strategy", body)
        dump_json(r)

    elif sub == "darkweb":
        header("DARK WEB SEARCH")
        r = api_post("/api/intel/darkweb", {"query": args.query}, timeout=60)
        dump_json(r)


